{
  "git_executable": "git",
  "version_pair": {
    "repo_path": "cpp_release_note_mvp/workspaces/third_party_sqlite",
    "ref_version": "REF_TAG",
    "tgt_version": "TGT_TAG"
  },
  "include_extensions": [
    ".c",
    ".cc",
    ".cpp",
    ".cxx",
    ".h",
    ".hh",
    ".hpp",
    ".hxx"
  ],
  "diff_context_lines": 0,
  "output_dir": "cpp_release_note_mvp/outputs",
  "project": {
    "name": "third_party_sqlite",
    "description": "Optional short project description used by Stage 3 prompts."
  },
  "cmg": {
    "strategy": "adaptive",
    "matching_view": "strict",
    "context_hops": 1,
    "matched_hops": 1,
    "sparse_matched_hops": 2,
    "unmatched_expand_hops": 1,
    "unmatched_source_window_lines": 80,
    "unmatched_expand_from_diff_calls": true,
    "min_edges_for_sparse": 1,
    "include_parent_context": true,
    "include_diff_calls": true,
    "max_nodes": 30,
    "max_edges": 60
  },
  "generation": {
    "backend": "mock",
    "model_name": "mock-rule-based-v1",
    "base_url": "https://api.openai.com/v1",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.2,
    "max_tokens": 256,
    "timeout_sec": 60,
    "max_retries": 2,
    "retry_backoff_sec": 1.5
  },
  "enre": {
    "java_executable": "java",
    "enre_jar_path": "tools/ENRE-CPP.jar",
    "max_heap": "8g",
    "snapshot_root": "cpp_release_note_mvp/workspaces/version_snapshots",
    "project_name": "third_party_sqlite",
    "extra_dirs": [],
    "program_environments": [],
    "raw_output_root": "cpp_release_note_mvp/outputs/enre_raw"
  }
}
